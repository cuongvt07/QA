# Google Gemini API Key
# Required for AI Final Preview Evaluation
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional: Server port (defaults to 8090)
PORT=8090

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=customily-pod-tester

# Test Evaluation Settings
DIFF_AUTO_PASS_ZERO=true
DIFF_AUTO_PASS_HIGH=50

timeout=15
headless=true

# Mail Settings
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Performance configuration: Ram 4GB safe limit
SERVER_QUEUE_CONCURRENCY=3
RUN_QUEUE_CONCURRENCY=3

# Daily Auto-Test Configuration
# Max test cases to queue daily (syncs with UI settings)
DAILY_NEW_TC_LIMIT=500
# Email to receive the Daily End-Of-Batch Excel Report
DAILY_REPORT_TO=admin@example.com
DAILY_REPORT_CC=

# OpenAI API Key
# Required for AI Final QA Validation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Server port (defaults to 8090)
PORT=8090

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=pod_user
DB_PASSWORD=pod_password
DB_NAME=customily-pod-tester
DB_ROOT_PASSWORD=root_password

# Test Evaluation Settings
DIFF_AUTO_PASS_ZERO=true
DIFF_AUTO_PASS_HIGH=50

# Application Configuration
timeout=15
headless=true

# Daily Report & Evaluation
DAILY_REPORT_TIME=23:50
DAILY_REPORT_TO=admin@example.com
DAILY_REPORT_CC=dev@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=my_email@gmail.com
SMTP_PASS=app_password
